# UplinkIRC configuration example
# Copy to ~/.config/LinuxDojo/UplinkIRC/config.toml and set your nick.
# This file is created automatically on first launch if it does not exist.

[ui]
theme             = "catppuccin-mocha"  # theme name from themes/ folder
show_nick_prefix  = true                # show your nick next to the input box
show_topic        = true                # show the topic bar at the top
show_emoji_button = false               # show emoji button (picker coming soon)
colored_nicks     = true                # give each nick a unique color

[[server]]
name     = "LinuxDojo"            # display name in the sidebar
host     = "irc.linuxdojo.org"    # server hostname
port     = 6697                   # 6697 = standard TLS port
ssl      = true                   # always use TLS
nick     = "yournick"             # change this to your nickname
user     = "uplink"               # username in your hostmask
realname = "UplinkIRC User"       # shown in WHOIS
channels = "#uplink, #linux"      # channels to join on connect (comma-separated)

# Optional: server password (used for bouncers like ZNC or soju)
# password = "joe/network:mypassword"

# --- Multiple servers ---
# Add more [[server]] blocks to connect to additional networks.

# [[server]]
# name     = "Libera"
# host     = "irc.libera.chat"
# port     = 6697
# ssl      = true
# nick     = "yournick"
# user     = "uplink"
# realname = "UplinkIRC User"
# channels = "#linux, #archlinux"
